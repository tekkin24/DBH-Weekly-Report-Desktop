<Window x:Class="DBHWeeklyReport.App.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weekly Report Preview"
        Width="1200"
        Height="720"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" FontSize="16" />
            <TextBlock Text="{Binding Preview.ExcelPath}" Foreground="#555" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="110" Margin="0,0,8,0" Click="OnWriteClick">Write to Excel</Button>
            <Button Width="110" Click="OnCancelClick">Cancel</Button>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding ReportDate}" Width="100" />
                <DataGridTextColumn Header="状態" Binding="{Binding Status}" Width="90" />
                <DataGridTextColumn Header="タスク" Binding="{Binding Task}" Width="220" />
                <DataGridTextColumn Header="作業詳細" Binding="{Binding Detail}" Width="270" />
                <DataGridTextColumn Header="メモ" Binding="{Binding Memo}" Width="*" />
                <DataGridTextColumn Header="Commits" Binding="{Binding CommitCount}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
