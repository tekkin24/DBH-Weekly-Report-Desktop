<Window x:Class="DBHWeeklyReport.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Báo cáo tuần DBH"
        Width="940"
        Height="720"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16" Background="#F5F7FB" CornerRadius="10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Báo cáo tuần DBH" FontSize="24" FontWeight="Bold" />
                <TextBlock Margin="0,6,0,0"
                           Text="Xem trước báo cáo từ git commit và chỉ ghi vào Excel sau khi bạn xác nhận."
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="16" BorderBrush="#D7DCE5" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Đường dẫn repo" />
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" Text="{Binding RepositoryPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Row="0" Grid.Column="2" Margin="0,0,0,8" Click="OnBrowseRepositoryClick">Chọn</Button>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Đường dẫn file Excel" />
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,8,8" Text="{Binding ExcelPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Row="1" Grid.Column="2" Margin="0,0,0,8" Click="OnBrowseExcelClick">Chọn</Button>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Tên tác giả" />
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" Text="{Binding AuthorName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Email tác giả" />
                    <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" Text="{Binding AuthorEmail, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Ngày chạy tự động" />
                    <ComboBox Grid.Row="4"
                              Grid.Column="1"
                              Grid.ColumnSpan="2"
                              Margin="0,0,0,8"
                              ItemsSource="{Binding AvailableRunDays}"
                              SelectedValue="{Binding SelectedRunDay}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Label" />

                    <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Giờ chạy tự động" />
                    <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" Text="{Binding RunTimeText, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Ngày tham chiếu" />
                    <DatePicker Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" SelectedDate="{Binding SelectedReferenceDate}" />

                    <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Thư mục log" />
                    <TextBox Grid.Row="7" Grid.Column="1" Margin="0,0,8,8" Text="{Binding LogDirectory, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Row="7" Grid.Column="2" Margin="0,0,0,8" Click="OnBrowseLogDirectoryClick">Chọn</Button>

                    <CheckBox Grid.Row="8"
                              Grid.Column="1"
                              Grid.ColumnSpan="2"
                              Margin="0,4,0,8"
                              IsChecked="{Binding AutoStartWithWindows}"
                              Content="Tự chạy cùng Windows" />

                    <CheckBox Grid.Row="9"
                              Grid.Column="1"
                              Grid.ColumnSpan="2"
                              Margin="0,0,0,12"
                              IsChecked="{Binding UseWindowsTaskScheduler}"
                              Content="Dùng Windows Task Scheduler để tự bật đúng giờ" />

                    <StackPanel Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal">
                        <Button Width="110" Margin="0,0,8,0" Click="OnSaveClick">Lưu</Button>
                        <Button Width="110" Margin="0,0,8,0" Click="OnRunNowClick">Chạy ngay</Button>
                        <Button Width="160" Margin="0,0,8,0" Click="OnPreviewSelectedWeekClick">Xem trước tuần đã chọn</Button>
                        <Button Width="110" Click="OnOpenLogsClick">Mở log</Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="16" BorderBrush="#D7DCE5" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Trạng thái" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Margin="0,8,0,0" Text="{Binding StatusText}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,16,0,0" Text="Lần chạy kế tiếp" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0" Text="{Binding NextRunText}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,16,0,0" Text="Chế độ tự động" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0" Text="Chạy nền + xác nhận xem trước trước khi ghi Excel" TextWrapping="Wrap" />
                    <TextBlock Margin="0,16,0,0" Text="Lịch hiện tại" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0" Text="{Binding ScheduleText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="4,12,0,0"
                   Foreground="#666"
                   Text="Đóng cửa sổ sẽ thu nhỏ app xuống khay hệ thống. Hãy dùng menu khay để mở lại hoặc thoát." />
    </Grid>
</Window>
