<Window x:Class="DBHWeeklyReport.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DBH Weekly Report Desktop"
        Width="940"
        Height="640"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16" Background="#F5F7FB" CornerRadius="10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="DBH Weekly Report Desktop" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="Git commit から週次報告をプレビューし、確認後に Excel へ反映する。" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="16" BorderBrush="#D7DCE5" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Repository path" />
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" Text="{Binding RepositoryPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Row="0" Grid.Column="2" Margin="0,0,0,8" Click="OnBrowseRepositoryClick">Browse</Button>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Excel file path" />
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,8,8" Text="{Binding ExcelPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Row="1" Grid.Column="2" Margin="0,0,0,8" Click="OnBrowseExcelClick">Browse</Button>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Author name" />
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" Text="{Binding AuthorName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Author email" />
                    <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" Text="{Binding AuthorEmail, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Run time" />
                    <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" Text="{Binding RunTimeText, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Reference date" />
                    <DatePicker Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" SelectedDate="{Binding SelectedReferenceDate}" />

                    <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Log directory" />
                    <TextBox Grid.Row="6" Grid.Column="1" Margin="0,0,8,8" Text="{Binding LogDirectory, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Row="6" Grid.Column="2" Margin="0,0,0,8" Click="OnBrowseLogDirectoryClick">Browse</Button>

                    <CheckBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,4,0,12" IsChecked="{Binding AutoStartWithWindows}" Content="Start automatically with Windows" />

                    <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal">
                        <Button Width="110" Margin="0,0,8,0" Click="OnSaveClick">Save</Button>
                        <Button Width="110" Margin="0,0,8,0" Click="OnRunNowClick">Run now</Button>
                        <Button Width="140" Margin="0,0,8,0" Click="OnPreviewSelectedWeekClick">Preview selected week</Button>
                        <Button Width="110" Click="OnOpenLogsClick">Open logs</Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="16" BorderBrush="#D7DCE5" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Status" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Margin="0,8,0,0" Text="{Binding StatusText}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,16,0,0" Text="Next scheduled run" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0" Text="{Binding NextRunText}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,16,0,0" Text="Automation mode" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0" Text="Background scheduler + preview confirmation" TextWrapping="Wrap" />
                    <TextBlock Margin="0,16,0,0" Text="Schedule" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0" Text="Every Friday" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="4,12,0,0"
                   Foreground="#666"
                   Text="Closing the window keeps the app in the system tray. Use tray menu to reopen or exit." />
    </Grid>
</Window>
